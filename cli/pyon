#!/usr/bin/env bash
# pyon — scaffold a new project from the pyon-stack template.
# shellcheck shell=bash

set -euo pipefail

PYON_VERSION="0.3.0"
PYON_REPO_DEFAULT="https://github.com/K4L-EL/pyon-stack.git"
PYON_REPO="${PYON_REPO:-$PYON_REPO_DEFAULT}"
PYON_OPENAI_MODEL="${PYON_OPENAI_MODEL:-gpt-5.4}"
PYON_OPENAI_FALLBACK_MODEL="${PYON_OPENAI_FALLBACK_MODEL:-gpt-4o}"
PYON_OPENAI_URL="${PYON_OPENAI_URL:-https://api.openai.com/v1/chat/completions}"

# Known IDs (kept in sync with themes/ palettes/ fonts/).
PYON_THEMES="minimalist neo-brutalism glassmorphism claymorphism retro-synthwave terminal"
PYON_PALETTES="slate zinc emerald rose indigo amber teal cyan"
PYON_FONTS="inter geist space-grotesk ibm-plex-sans poppins bricolage-grotesque playfair-display atkinson-hyperlegible jetbrains-mono ibm-plex-mono"

# --- pretty logging ---------------------------------------------------------
if [ -t 1 ]; then
  C_R=$'\033[0m'; C_B=$'\033[1m'; C_DIM=$'\033[2m'
  C_CYAN=$'\033[36m'; C_YEL=$'\033[33m'; C_RED=$'\033[31m'; C_GRN=$'\033[32m'
else
  C_R=''; C_B=''; C_DIM=''; C_CYAN=''; C_YEL=''; C_RED=''; C_GRN=''
fi
say()  { printf '%s%s%s\n' "$C_CYAN" "$*" "$C_R"; }
ok()   { printf '%s✓%s %s\n' "$C_GRN" "$C_R" "$*"; }
warn() { printf '%s!%s %s\n' "$C_YEL" "$C_R" "$*" >&2; }
die()  { printf '%s✗%s %s\n' "$C_RED" "$C_R" "$*" >&2; exit 1; }

# --- help -------------------------------------------------------------------
usage() {
  cat <<'EOF'
pyon — scaffold a new project from the pyon-stack template.

Usage:
  pyon new [NAME] [options]       Create a new project
  pyon update                     Pull latest template into ./pyon-stack-latest/ and diff
  pyon --version | -v             Show CLI version
  pyon --help    | -h             This help

Options for `pyon new`:
  --yes                     Accept defaults, skip prompts
  --display    <str>        Display name (e.g. "Acme Inc")
  --namespace  <id>         .NET namespace (PascalCase)
  --db         <name>       Postgres database name (snake_case)
  --port-web   <port>       Marketing site port (default 3000)
  --port-app   <port>       Dashboard port (default 5173)
  --port-api   <port>       API port (default 5080)
  --port-db    <port>       Postgres port (default 5432)
  --gh-owner   <login>      GitHub owner for repo creation
  --create-repo             Create GitHub repo (needs `gh` CLI, authenticated)
  --no-create-repo          Skip GitHub repo creation
  --up                      After scaffold: docker compose up -d --build,
                            then wait for the API/web/app to respond and
                            print local URLs
  --no-up                   Skip docker compose
  --repo       <git-url>    Use a custom template repo URL
                            (env: PYON_REPO)
  --template-dir <path>     Use a local directory instead of cloning
                            (env: PYON_TEMPLATE_DIR)

Design:
  --theme      <id>         One of: minimalist neo-brutalism glassmorphism
                            claymorphism retro-synthwave terminal
  --palette    <id|none>    One of: slate zinc emerald rose indigo amber teal cyan
                            (or 'none' to keep the theme's own colors)
  --font       <id>         One of: inter geist space-grotesk ibm-plex-sans poppins
                            bricolage-grotesque playfair-display
                            atkinson-hyperlegible jetbrains-mono ibm-plex-mono
  --ref-url    <url>        Reference website — GPT infers full brand from it
                            (palette + font + theme + copy/tone)
  --describe   <text>       Product description — GPT fills placeholder copy
  --no-ai                   Skip AI steps entirely; use picks + curated copy

Environment:
  PYON_REPO                 Default template git URL
  PYON_TEMPLATE_DIR         Path to local pyon-stack checkout (skips clone)
  PYON_OPENAI_MODEL         Model id for brand inference (default: gpt-5.4)
  PYON_OPENAI_FALLBACK_MODEL  Fallback model if main model is unavailable (default: gpt-4o)
  OPENAI_API_KEY            If set, used non-interactively for AI steps
EOF
}

# --- utilities --------------------------------------------------------------

require() {
  command -v "$1" >/dev/null 2>&1 || die "Required tool not found: $1"
}

require_any() {
  for t in "$@"; do command -v "$t" >/dev/null 2>&1 && return 0; done
  die "Need one of: $*"
}

rand_hex() {
  # 48 hex chars = 192 bits
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 24
  else
    LC_ALL=C tr -dc 'a-f0-9' </dev/urandom 2>/dev/null | head -c 48
  fi
}

# Portable in-place sed. macOS sed needs `-i ''`, GNU sed wants `-i`.
# Usage: sed_inplace <expr> <file>
sed_inplace() {
  if sed --version >/dev/null 2>&1; then
    sed -i "$1" "$2"
  else
    sed -i '' "$1" "$2"
  fi
}

# lowercase
lower() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

# slugify: lowercase, non-alnum -> '-', collapse, trim
slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

snake() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//'
}

pascal() {
  printf '%s' "$1" | awk 'BEGIN{FS="[^A-Za-z0-9]+"; OFS=""}{
    for (i=1;i<=NF;i++) {
      s=$i; if (s=="") continue;
      printf "%s%s", toupper(substr(s,1,1)), tolower(substr(s,2));
    } print ""
  }'
}

prompt() {
  local msg="$1" def="${2:-}" reply
  if [ "${YES:-0}" = "1" ]; then
    printf '%s\n' "$def"
    return 0
  fi
  if [ -n "$def" ]; then
    printf '%s%s%s [%s]: ' "$C_B" "$msg" "$C_R" "$def" >&2
  else
    printf '%s%s%s: ' "$C_B" "$msg" "$C_R" >&2
  fi
  read -r reply </dev/tty || reply=""
  printf '%s\n' "${reply:-$def}"
}

prompt_yn() {
  local msg="$1" def="${2:-n}" reply
  if [ "${YES:-0}" = "1" ]; then
    printf '%s\n' "$def"
    return 0
  fi
  printf '%s%s%s (y/N) [%s]: ' "$C_B" "$msg" "$C_R" "$def" >&2
  read -r reply </dev/tty || reply=""
  reply="${reply:-$def}"
  case "$(lower "$reply")" in y|yes) printf 'y\n' ;; *) printf 'n\n' ;; esac
}

