# Restore terminal state after an arrow-key menu (shared trap handler).
__pyon_restore_tty() {
  [ -n "${__PYON_SAVED_STTY:-}" ] && stty "$__PYON_SAVED_STTY" </dev/tty 2>/dev/null || true
  printf '\033[?25h' >/dev/tty 2>/dev/null || true   # show cursor
  __PYON_SAVED_STTY=""
}

# Plain numbered fallback — used when stdin isn't a TTY, or the user sets
# PYON_NO_ARROW_MENU=1.
_prompt_choice_numbered() {
  local title="$1" def="$2"; shift 2
  local ids=("$@") i=1 def_idx=1
  {
    printf '%s%s%s\n' "$C_B" "$title" "$C_R"
    for id in "${ids[@]}"; do
      [ "$id" = "$def" ] && def_idx=$i
      printf '  %d) %s%s\n' "$i" "$(_option_label "$id")" \
        "$([ "$id" = "$def" ] && printf ' %s(default)%s' "$C_DIM" "$C_R" || true)"
      i=$((i+1))
    done
    printf 'Choose 1-%d [%d]: ' "${#ids[@]}" "$def_idx"
  } >&2
  local reply
  read -r reply </dev/tty || reply=""
  reply="${reply:-$def_idx}"
  case "$reply" in
    ''|*[!0-9]*) printf '%s\n' "$def"; return 0 ;;
  esac
  if [ "$reply" -ge 1 ] && [ "$reply" -le "${#ids[@]}" ]; then
    printf '%s\n' "${ids[$((reply-1))]}"
  else
    printf '%s\n' "$def"
  fi
}

# Arrow-key multi-choice picker with emoji labels and live highlight.
# Usage: prompt_choice <title> <default-id> <id1> <id2> ...
# Prints the chosen id to stdout; renders the UI on /dev/tty.
# Falls back to _prompt_choice_numbered when /dev/tty is unavailable, on
# YES mode, or when PYON_NO_ARROW_MENU=1.
prompt_choice() {
  local title="$1" def="$2"; shift 2
  local ids=("$@")
  local n=${#ids[@]}

  if [ "${YES:-0}" = "1" ]; then
    printf '%s\n' "$def"
    return 0
  fi

  if [ "${PYON_NO_ARROW_MENU:-0}" = "1" ] || ! { [ -r /dev/tty ] && [ -w /dev/tty ]; }; then
    _prompt_choice_numbered "$title" "$def" "${ids[@]}"
    return $?
  fi

  # Save terminal state so we can always restore on Ctrl+C / failure.
  __PYON_SAVED_STTY=$(stty -g </dev/tty 2>/dev/null || printf '')
  if [ -z "$__PYON_SAVED_STTY" ]; then
    _prompt_choice_numbered "$title" "$def" "${ids[@]}"
    return $?
  fi
  stty -echo -icanon min 1 time 0 </dev/tty 2>/dev/null || {
    _prompt_choice_numbered "$title" "$def" "${ids[@]}"
    return $?
  }
  printf '\033[?25l' >/dev/tty   # hide cursor
  # shellcheck disable=SC2064  # intentional: expand $PYON_SAVED_STTY at trap-set time
  trap '__pyon_restore_tty; trap - INT TERM; exit 130' INT TERM

  local sel=0 i
  for i in "${!ids[@]}"; do
    [ "${ids[$i]}" = "$def" ] && sel=$i
  done

  _draw() {
    printf '%s%s%s  %s(↑/↓ to move · Enter to select)%s\n' \
      "$C_B" "$title" "$C_R" "$C_DIM" "$C_R" >/dev/tty
    for i in "${!ids[@]}"; do
      if [ "$i" = "$sel" ]; then
        printf '  %s❯ %s%s\n' "$C_CYAN" "$(_option_label "${ids[$i]}")" "$C_R" >/dev/tty
      else
        printf '    %s%s%s\n' "$C_DIM" "$(_option_label "${ids[$i]}")" "$C_R" >/dev/tty
      fi
    done
  }

  _draw
  local key k2 k3
  while :; do
    IFS= read -rsn1 key </dev/tty || key=""
    if [ "$key" = $'\x1b' ]; then
      # Give the rest of the escape sequence a brief moment to arrive.
      IFS= read -rsn1 -t 1 k2 </dev/tty || k2=""
      IFS= read -rsn1 -t 1 k3 </dev/tty || k3=""
      key="$key$k2$k3"
    fi

    case "$key" in
      $'\x1b[A'|'k') sel=$(( (sel - 1 + n) % n )) ;;
      $'\x1b[B'|'j') sel=$(( (sel + 1) % n )) ;;
      ''|$'\n')      break ;;
      $'\x03')       __pyon_restore_tty; trap - INT TERM; exit 130 ;;
      q|Q)           __pyon_restore_tty; trap - INT TERM; exit 130 ;;
      *)             continue ;;
    esac

    # Move cursor up over (title + n items) and redraw.
    printf '\033[%dA' "$((n + 1))" >/dev/tty
    _draw
  done

  __pyon_restore_tty
  trap - INT TERM

  # Collapse the menu into a single "Title: ✓ value" summary line.
  printf '\033[%dA' "$((n + 1))" >/dev/tty
  local _k
  for ((_k = 0; _k <= n; _k++)); do printf '\033[2K\n' >/dev/tty; done
  printf '\033[%dA' "$((n + 1))" >/dev/tty
  printf '%s%s%s: %s✓%s %s%s%s\n' \
    "$C_B" "$title" "$C_R" "$C_GRN" "$C_R" "$C_CYAN" "${ids[$sel]}" "$C_R" >/dev/tty

  printf '%s\n' "${ids[$sel]}"
}

# Silent secret prompt. Prints value to stdout, reads from /dev/tty.
prompt_secret() {
  local msg="$1" reply=""
  if [ "${YES:-0}" = "1" ]; then
    printf '\n'
    return 0
  fi
  printf '%s%s%s: ' "$C_B" "$msg" "$C_R" >&2
  # shellcheck disable=SC2162
  (stty -echo 2>/dev/null; read reply </dev/tty; stty echo 2>/dev/null; printf '\n' >&2) \
    || read -r reply </dev/tty || reply=""
  # The stty subshell swallows reply; read in parent instead for reliability.
  if [ -z "$reply" ]; then
    stty -echo 2>/dev/null || true
    IFS= read -r reply </dev/tty || reply=""
    stty echo 2>/dev/null || true
    printf '\n' >&2
  fi
  printf '%s' "$reply"
}

in_list() {
  local needle="$1"; shift
  local hay
  for hay in "$@"; do [ "$hay" = "$needle" ] && return 0; done
  return 1
}

# Convert a #RRGGBB (or #RGB) hex to shadcn-style HSL: "H S% L%".
hex_to_hsl() {
  local hex="${1#\#}"
  if [ "${#hex}" = 3 ]; then
    hex="${hex:0:1}${hex:0:1}${hex:1:1}${hex:1:1}${hex:2:1}${hex:2:1}"
  fi
  if ! [[ "$hex" =~ ^[0-9a-fA-F]{6}$ ]]; then
    printf '0 0%% 50%%'; return 0
  fi
  local r g b
  r=$((16#${hex:0:2})); g=$((16#${hex:2:2})); b=$((16#${hex:4:2}))
  awk -v r="$r" -v g="$g" -v b="$b" 'BEGIN {
    r=r/255; g=g/255; b=b/255;
    max=(r>g?r:g); if(b>max)max=b;
    min=(r<g?r:g); if(b<min)min=b;
    l=(max+min)/2; h=0; s=0;
    if (max != min) {
      d=max-min;
      s=(l>0.5)?d/(2-max-min):d/(max+min);
      if (max==r) h=(g-b)/d + (g<b?6:0);
      else if (max==g) h=(b-r)/d + 2;
      else h=(r-g)/d + 4;
      h=h*60;
    }
    printf "%d %d%% %d%%", int(h+0.5), int(s*100+0.5), int(l*100+0.5);
  }'
}

# --- AI helpers -------------------------------------------------------------

# Reads OpenAI key from OPENAI_API_KEY or prompts once. Echoes it. Returns 1 if
# user declines / empty. The key is never persisted.
ai_require_key() {
  if [ -n "${OPENAI_API_KEY:-}" ]; then
    printf '%s' "$OPENAI_API_KEY"; return 0
  fi
  if [ "${YES:-0}" = "1" ]; then return 1; fi
  local k
  k=$(prompt_secret "OpenAI API key (not saved)")
  [ -z "$k" ] && return 1
  printf '%s' "$k"
}

# ai_chat_json <key> <system> <user>  →  prints the parsed assistant JSON.
# Uses response_format=json_object. Retries once on transient failure.
# Falls back to $PYON_OPENAI_FALLBACK_MODEL if the primary model errors with "model_not_found".
ai_chat_json() {
  local key="$1" sys="$2" usr="$3"
  local attempt=0 resp http model="$PYON_OPENAI_MODEL"
  while [ "$attempt" -lt 3 ]; do
    attempt=$((attempt+1))
    local body
    body=$(jq -n \
      --arg model "$model" \
      --arg sys "$sys" \
      --arg usr "$usr" \
      '{
         model: $model,
         messages: [ {role:"system", content:$sys}, {role:"user", content:$usr} ],
         response_format: { type: "json_object" }
       }')
    resp=$(mktemp); http=$(mktemp)
    local code
    code=$(curl -sS --max-time 60 \
      -w '%{http_code}' -o "$resp" \
      -H "Authorization: Bearer $key" \
      -H "Content-Type: application/json" \
      -d "$body" \
      "$PYON_OPENAI_URL" 2>"$http" || echo "000")
    if [ "$code" = "200" ]; then
      local content
      content=$(jq -r '.choices[0].message.content // empty' <"$resp")
      rm -f "$resp" "$http"
      if [ -n "$content" ] && printf '%s' "$content" | jq empty >/dev/null 2>&1; then
        printf '%s' "$content"
        return 0
      fi
    else
      if [ "$code" = "404" ] && [ "$model" != "$PYON_OPENAI_FALLBACK_MODEL" ] \
         && jq -r '.error.code // empty' <"$resp" 2>/dev/null | grep -q 'model_not_found'; then
        warn "Model $model not available, falling back to $PYON_OPENAI_FALLBACK_MODEL"
        model="$PYON_OPENAI_FALLBACK_MODEL"
        rm -f "$resp" "$http"
        continue
      fi
      warn "OpenAI error (http=$code, attempt=$attempt)"
    fi
    rm -f "$resp" "$http"
    sleep 2
  done
  return 1
}

# Poll an HTTP URL until it returns 2xx/3xx, or until the timeout elapses.
# Usage: wait_http <url> <timeout-seconds> [label]
# Writes a one-line progress indicator while waiting.
wait_http() {
  local url="$1" timeout="${2:-120}" label="${3:-$1}"
  local start now elapsed code
  start=$(date +%s)
  printf '%s  waiting for %s ' "$C_DIM" "$label"
  while :; do
    code=$(curl -s -o /dev/null -m 3 -w '%{http_code}' "$url" 2>/dev/null || printf '000')
    if [ "$code" -ge 200 ] 2>/dev/null && [ "$code" -lt 400 ] 2>/dev/null; then
      printf '%s\n' "$C_R"
      return 0
    fi
    now=$(date +%s); elapsed=$((now - start))
    if [ "$elapsed" -ge "$timeout" ]; then
      printf '(timeout after %ss, last code %s)%s\n' "$timeout" "$code" "$C_R"
      return 1
    fi
    printf '.'
    sleep 2
  done
}

# Fetch a URL and strip tags, keeping a readable text+inline-css slice for GPT.
ai_fetch_clean() {
  local url="$1" out
  out=$(mktemp)
  curl -sSL --max-time 20 -A "Mozilla/5.0 pyon-cli/$PYON_VERSION" "$url" -o "$out" 2>/dev/null || { rm -f "$out"; return 1; }
  # Keep <style> blocks intact (useful for palette extraction), strip <script>,
  # collapse tags elsewhere to plain text.
  awk '
    BEGIN { in_script=0 }
    /<script[^>]*>/ { in_script=1 }
    /<\/script>/    { in_script=0; next }
    !in_script { print }
  ' "$out" \
    | sed -E 's/<[[:space:]]*br[[:space:]]*\/?[[:space:]]*>/\n/g' \
    | perl -0777 -pe 's{<(?!style|/style)[^>]+>}{ }g; s/[[:space:]]+/ /g' 2>/dev/null \
    | head -c 20000
  rm -f "$out"
}

