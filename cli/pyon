EOF
}

# --- commands ---------------------------------------------------------------

cmd_version() { printf 'pyon %s\n' "$PYON_VERSION"; }

cmd_new() {
  local name="" display="" ns="" db=""
  local port_web="3000" port_app="5173" port_api="5080" port_db="5432"
  local gh_owner="" create_repo="" run_up="" template_dir="${PYON_TEMPLATE_DIR:-}"
  local theme="" palette="" font="" ref_url="" description="" no_ai=""
  YES=0

  # parse flags
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes) YES=1 ;;
      --display) display="$2"; shift ;;
      --namespace) ns="$2"; shift ;;
      --db) db="$2"; shift ;;
      --port-web) port_web="$2"; shift ;;
      --port-app) port_app="$2"; shift ;;
      --port-api) port_api="$2"; shift ;;
      --port-db) port_db="$2"; shift ;;
      --gh-owner) gh_owner="$2"; shift ;;
      --create-repo) create_repo="y" ;;
      --no-create-repo) create_repo="n" ;;
      --up) run_up="y" ;;
      --no-up) run_up="n" ;;
      --repo) PYON_REPO="$2"; shift ;;
      --template-dir) template_dir="$2"; shift ;;
      --theme) theme="$2"; shift ;;
      --palette) palette="$2"; shift ;;
      --font) font="$2"; shift ;;
      --ref-url) ref_url="$2"; shift ;;
      --describe) description="$2"; shift ;;
      --no-ai) no_ai="1" ;;
      -h|--help) usage; return 0 ;;
      -*) die "Unknown flag: $1 (try --help)" ;;
      *) if [ -z "$name" ]; then name="$1"; else die "Unexpected argument: $1"; fi ;;
    esac
    shift
  done

  # preflight
  require git
  require tar
  require jq
  require curl
  if [ -z "$template_dir" ]; then require git; fi

  # Validate design flags where provided up-front.
  if [ -n "$theme" ] && ! in_list "$theme" $PYON_THEMES; then
    die "Unknown --theme: $theme (valid: $PYON_THEMES)"
  fi
  if [ -n "$palette" ] && [ "$palette" != "none" ] && ! in_list "$palette" $PYON_PALETTES; then
    die "Unknown --palette: $palette (valid: none $PYON_PALETTES)"
  fi
  if [ -n "$font" ] && ! in_list "$font" $PYON_FONTS; then
    die "Unknown --font: $font (valid: $PYON_FONTS)"
  fi

  say "PYON stack — new project"

  [ -z "$name" ] && name=$(prompt "Project slug (kebab-case)" "my-app")
  name=$(slugify "$name")
  [ -z "$name" ] && die "Project name is required"
  [ -e "$name" ] && die "Directory '$name' already exists"

  [ -z "$display" ] && display=$(prompt "Display name" "$(printf '%s' "$name" | sed -E 's/-/ /g' | awk '{for(i=1;i<=NF;i++)$i=toupper(substr($i,1,1)) tolower(substr($i,2));print}')")
  [ -z "$ns" ] && ns=$(prompt ".NET namespace (PascalCase)" "$(pascal "$name")")
  [ -z "$db" ] && db=$(prompt "Postgres database name (snake_case)" "$(snake "$name")")

  [ -z "$port_web" ] && port_web="3000"
  [ -z "$port_app" ] && port_app="5173"
  [ -z "$port_api" ] && port_api="5080"
  [ -z "$port_db" ]  && port_db="5432"
  if [ "$YES" != "1" ]; then
    port_web=$(prompt "Marketing site port" "$port_web")
    port_app=$(prompt "Dashboard port"       "$port_app")
    port_api=$(prompt "API port"             "$port_api")
    port_db=$(prompt  "Postgres port"        "$port_db")
  fi

  [ -z "$gh_owner" ] && gh_owner=$(prompt "GitHub owner (for repo + images)" "$(git config --global user.name 2>/dev/null || echo yourname)")
  [ -z "$create_repo" ] && create_repo=$(prompt_yn "Create GitHub repo with 'gh' now?" "n")
  [ -z "$run_up" ] && run_up=$(prompt_yn "Run 'docker compose up -d' after scaffold?" "n")

  # --- design picks --------------------------------------------------------
  local palette_mode="preset"
  local hex_primary="" hex_background="" hex_accent=""

  [ -z "$theme" ] && theme=$(prompt_choice "Design style" "minimalist" $PYON_THEMES)

  # Palette mode
  if [ -z "$palette" ]; then
    palette_mode=$(prompt_choice "Color palette source" "preset" preset theme-default hex url)
    case "$palette_mode" in
      preset) palette=$(prompt_choice "Preset palette" "slate" $PYON_PALETTES) ;;
      theme-default) palette="none" ;;
      hex)
        hex_primary=$(prompt    "Primary hex (e.g. #4f46e5)"   "#4f46e5")
        hex_background=$(prompt "Background hex"               "#ffffff")
        hex_accent=$(prompt     "Accent hex"                   "#22c55e")
        ;;
      url)
        ref_url=${ref_url:-$(prompt "Reference website URL" "")}
        ;;
    esac
  fi

  # Font
  if [ -z "$font" ]; then
    font=$(prompt_choice "Font" "inter" $PYON_FONTS)
  fi

  # Copy source: description or ref URL (if not already set).
  if [ -z "$description" ] && [ -z "$ref_url" ]; then
    if [ "$YES" != "1" ]; then
      description=$(prompt "Describe your product (or leave blank)" "")
      if [ -z "$description" ]; then
        ref_url=$(prompt "…or paste a reference URL (or leave blank)" "")
      fi
    fi
  fi

  # Decide whether AI is needed.
  local need_ai=0
  [ "$palette_mode" = "url" ] && need_ai=1
  [ -n "$ref_url" ] && need_ai=1
  [ -n "$description" ] && need_ai=1
  [ "$no_ai" = "1" ] && need_ai=0

  local openai_key=""
  if [ "$need_ai" = "1" ]; then
    if ! openai_key=$(ai_require_key); then
      warn "No OpenAI key — skipping AI steps, using picks + curated fallback copy."
      need_ai=0
    fi
  fi

  local jwt year
  jwt=$(rand_hex)
  year=$(date +%Y)

  # --- fetch template -------------------------------------------------------
  if [ -n "$template_dir" ]; then
    [ -d "$template_dir" ] || die "template-dir not found: $template_dir"
    say "Copying template from $template_dir ..."
    # Copy, excluding .git and node_modules
    mkdir -p "$name"
    (
      cd "$template_dir"
      tar --exclude='.git' --exclude='node_modules' --exclude='bin' \
          --exclude='obj' --exclude='.next' --exclude='dist' -cf - .
    ) | tar -xf - -C "$name"
  else
    say "Cloning template ($PYON_REPO) ..."
    git clone --depth=1 "$PYON_REPO" "$name" >/dev/null
    rm -rf "$name/.git"
  fi

  # --- design: AI inference + apply ----------------------------------------
  CHOSEN_THEME="$theme"
  CHOSEN_FONT="$font"
  PALETTE_FILE=""
  COPY_FILE=""

  if [ "$need_ai" = "1" ] && [ -n "$ref_url" ]; then
    say "Asking $PYON_OPENAI_MODEL to read $ref_url ..."
    local brand_json
    brand_json=$(mktemp)
    if ai_scrape_brand "$openai_key" "$ref_url" > "$brand_json" 2>/dev/null \
        && jq empty < "$brand_json" >/dev/null 2>&1; then
      digest_brand_json "$name" "$brand_json"
      # If the user explicitly passed --theme/--palette/--font those win over GPT.
      [ -n "$theme" ] && CHOSEN_THEME="$theme"
      [ -n "$font" ]  && CHOSEN_FONT="$font"
      if [ -n "$palette" ] && [ "$palette" != "none" ]; then
        PALETTE_FILE="$name/palettes/$palette.json"
      fi
      ok "Brand inferred: theme=$CHOSEN_THEME font=$CHOSEN_FONT"
    else
      warn "Brand scrape failed — using picks + fallback copy."
      need_ai=0
    fi
    rm -f "$brand_json"
  fi

  if [ "$need_ai" = "1" ] && [ -n "$description" ] && [ -z "$COPY_FILE" ]; then
    say "Asking $PYON_OPENAI_MODEL to write copy ..."
    local copy_json
    copy_json=$(mktemp)
    if ai_generate_copy "$openai_key" "$display" "$CHOSEN_THEME" "${palette:-none}" "$CHOSEN_FONT" "$description" > "$copy_json" 2>/dev/null \
        && jq empty < "$copy_json" >/dev/null 2>&1; then
      COPY_FILE="$name/.pyon-copy.json"
      mv "$copy_json" "$COPY_FILE"
      ok "Copy generated."
    else
      warn "Copy generation failed — using curated fallback."
      rm -f "$copy_json"
    fi
  fi

  # If no PALETTE_FILE yet, resolve from --palette flag / preset pick / hex.
  if [ -z "$PALETTE_FILE" ]; then
    case "${palette_mode:-preset}" in
      hex)
        PALETTE_FILE="$name/.pyon-palette.json"
        palette_from_hex "$hex_primary" "$hex_background" "$hex_accent" "$PALETTE_FILE"
        ;;
      *)
        if [ -z "$palette" ] || [ "$palette" = "none" ]; then
          PALETTE_FILE="none"
        else
          PALETTE_FILE="$name/palettes/$palette.json"
        fi
        ;;
    esac
  fi

  say "Applying theme '$CHOSEN_THEME' ..."
  apply_theme "$name" "$CHOSEN_THEME"

  if [ "$PALETTE_FILE" != "none" ]; then
    say "Applying palette ..."
    apply_palette "$name" "$PALETTE_FILE"
  fi

  say "Applying font '$CHOSEN_FONT' ..."
  apply_font "$name" "$CHOSEN_FONT"

  # Copy: merge AI-generated (if any) with curated fallback so every slot fills.
  local merged_copy="$name/.pyon-copy-merged.json"
  if [ -n "$COPY_FILE" ] && [ -f "$COPY_FILE" ]; then
    merge_copy "$name/cli/fallbacks/copy.json" "$COPY_FILE" "$merged_copy"
  else
    cp "$name/cli/fallbacks/copy.json" "$merged_copy"
  fi
  say "Applying copy ..."
  apply_copy "$name" "$merged_copy"

  # --- rewrite tokens -------------------------------------------------------
  say "Rewriting placeholders ..."

  # Find every text file we need to touch. Skip binaries + common build dirs.
  local files
  files=$(mktemp)
  # grep -l will skip binary files by default
  ( cd "$name" && grep -rlE '__(PYON|pyon)_[A-Z_a-z]+__' \
      --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=bin \
      --exclude-dir=obj --exclude-dir=.next --exclude-dir=dist . \
      2>/dev/null || true ) > "$files"

  # Escape replacement values for sed (split into lines per token, one sed per
  # token = simpler and very fast on small templates).
  esc() { printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'; }

  local E_NAME E_DISPLAY E_NS E_DB E_PWEB E_PAPP E_PAPI E_PDB E_JWT E_OWN E_YEAR
  E_NAME=$(esc "$name")
  E_DISPLAY=$(esc "$display")
  E_NS=$(esc "$ns")
  E_DB=$(esc "$db")
  E_PWEB=$(esc "$port_web")
  E_PAPP=$(esc "$port_app")
  E_PAPI=$(esc "$port_api")
  E_PDB=$(esc "$port_db")
  E_JWT=$(esc "$jwt")
  E_OWN=$(esc "$gh_owner")
  E_YEAR=$(esc "$year")

  while IFS= read -r rel; do
    [ -z "$rel" ] && continue
    local f="$name/$rel"
    [ -f "$f" ] || continue
    sed_inplace "s/__PYON_DISPLAY_NAME__/$E_DISPLAY/g" "$f"
    sed_inplace "s/__PYON_NAMESPACE__/$E_NS/g"        "$f"
    sed_inplace "s/__PYON_PORT_WEB__/$E_PWEB/g"       "$f"
    sed_inplace "s/__PYON_PORT_APP__/$E_PAPP/g"       "$f"
    sed_inplace "s/__PYON_PORT_API__/$E_PAPI/g"       "$f"
    sed_inplace "s/__PYON_PORT_DB__/$E_PDB/g"         "$f"
    sed_inplace "s/__PYON_JWT_SECRET__/$E_JWT/g"      "$f"
    sed_inplace "s/__PYON_GH_OWNER__/$E_OWN/g"        "$f"
    sed_inplace "s/__PYON_YEAR__/$E_YEAR/g"           "$f"
    sed_inplace "s/__PYON_DB__/$E_DB/g"               "$f"
    sed_inplace "s/__PYON_NAME__/$E_NAME/g"           "$f"
    sed_inplace "s/__pyon_name__/$E_NAME/g"           "$f"
  done < "$files"
  rm -f "$files"

  # --- rename .NET project folder + sln + csproj ---------------------------
  if [ -d "$name/apps/api/Pyon.Api" ]; then
    mv "$name/apps/api/Pyon.Api" "$name/apps/api/${ns}.Api"
  fi
  if [ -f "$name/apps/api/${ns}.Api/Pyon.Api.csproj" ]; then
    mv "$name/apps/api/${ns}.Api/Pyon.Api.csproj" "$name/apps/api/${ns}.Api/${ns}.Api.csproj"
  fi
  if [ -f "$name/apps/api/Pyon.Api.sln" ]; then
    mv "$name/apps/api/Pyon.Api.sln" "$name/apps/api/${ns}.Api.sln"
    # Update sln references from Pyon.Api -> ${ns}.Api (only the string literals)
    sed_inplace "s/Pyon\.Api/${ns}.Api/g" "$name/apps/api/${ns}.Api.sln"
  fi

  # Dockerfile references
  if [ -f "$name/apps/api/Dockerfile" ]; then
    sed_inplace "s/Pyon\.Api\.sln/${ns}.Api.sln/g" "$name/apps/api/Dockerfile"
    sed_inplace "s/Pyon\.Api/${ns}.Api/g"           "$name/apps/api/Dockerfile"
  fi

  # Root package.json script references to apps/api/Pyon.Api
  if [ -f "$name/package.json" ]; then
    sed_inplace "s|apps/api/Pyon\.Api|apps/api/${ns}.Api|g" "$name/package.json"
    sed_inplace "s|apps/api/Pyon\.Api\.sln|apps/api/${ns}.Api.sln|g" "$name/package.json"
  fi

  # .env.example -> .env
  if [ -f "$name/.env.example" ]; then
    cp "$name/.env.example" "$name/.env"
  fi

  # Drop pyon-only assets from the generated project.
  rm -rf "$name/cli" "$name/install.sh"
  rm -rf "$name/themes" "$name/palettes" "$name/fonts"
  rm -f  "$name/.pyon-copy.json" "$name/.pyon-copy-merged.json" "$name/.pyon-palette.json"
  # docs/THEMES.md is template-internal documentation about pyon's design
  # system; scaffolded projects don't need it (they get their own README
  # and the design choices are already baked in).
  rm -f  "$name/docs/THEMES.md"
  rmdir "$name/docs" 2>/dev/null || true
  # The template's own CI workflows aren't meaningful in a new project.
  rm -f  "$name/.github/workflows/cli-smoke.yml" "$name/.github/workflows/ci.yml"

  # --- git init -------------------------------------------------------------
  say "Initializing git ..."
  (
    cd "$name"
    git init -q
    git add -A
    git -c user.email="pyon@local" -c user.name="pyon" commit -q -m "chore: scaffold from pyon-stack ${PYON_VERSION}"
  )

  # --- optional: create GitHub repo ----------------------------------------
  if [ "$(lower "$create_repo")" = "y" ]; then
    if command -v gh >/dev/null 2>&1; then
      (
        cd "$name"
        say "Creating GitHub repo $gh_owner/$name ..."
        gh repo create "$gh_owner/$name" --private --source=. --push || warn "gh repo create failed — skipping"
      )
    else
      warn "'gh' CLI not found — skipping repo creation. Install: https://cli.github.com"
    fi
  fi

  # --- optional: docker compose up -----------------------------------------
  local up_ok="n" api_ok="n" web_ok="n" app_ok="n"
  if [ "$(lower "$run_up")" = "y" ]; then
    if command -v docker >/dev/null 2>&1; then
      say "Starting docker compose (this may take a few minutes on first build) ..."
      if ( cd "$name" && docker compose -f docker/docker-compose.yml up -d --build ); then
        up_ok="y"
      else
        warn "docker compose failed — you can retry with: cd $name && docker compose -f docker/docker-compose.yml up -d --build"
      fi
    else
      warn "docker not found — skipping 'docker compose up'"
    fi
  fi

  # --- probe URLs (only if we actually started docker) --------------------
  if [ "$up_ok" = "y" ]; then
    say "Probing services ..."
    wait_http "http://localhost:$port_api/api/health" 180 "API"           && api_ok="y"
    wait_http "http://localhost:$port_web"            180 "marketing site" && web_ok="y"
    wait_http "http://localhost:$port_app"            180 "dashboard"      && app_ok="y"
  fi

  status_icon() { [ "$1" = "y" ] && printf '%s✓%s' "$C_GRN" "$C_R" || printf '%s•%s' "$C_DIM" "$C_R"; }

  # --- done ----------------------------------------------------------------
  ok "Project '$name' is ready."
  if [ "$up_ok" = "y" ]; then
    cat <<EOF

${C_B}Your stack is live locally${C_R}
  $(status_icon "$web_ok") Marketing site   http://localhost:$port_web
  $(status_icon "$app_ok") Dashboard        http://localhost:$port_app
  $(status_icon "$api_ok") API health       http://localhost:$port_api/api/health
  $(status_icon "$api_ok") API Swagger UI   http://localhost:$port_api/swagger
  •  Postgres          localhost:$port_db  (db: $db, user: pyon, password: pyon)

${C_DIM}Admin user (seeded automatically):${C_R}
  email:    admin@example.com
  password: change-me-now

${C_DIM}Manage the stack from inside the project dir:${C_R}
  cd $name
  docker compose -f docker/docker-compose.yml logs -f           # tail logs
  docker compose -f docker/docker-compose.yml ps                # list services
  docker compose -f docker/docker-compose.yml down              # stop
EOF
    if [ "$api_ok" != "y" ] || [ "$web_ok" != "y" ] || [ "$app_ok" != "y" ]; then
      warn "One or more services didn't respond within 180s. Check 'docker compose logs' in the project."
    fi
  else
    cat <<EOF

${C_B}Next steps${C_R}
  cd $name
  pnpm install
  docker compose -f docker/docker-compose.yml up -d --build
  open http://localhost:$port_web     # marketing site
  open http://localhost:$port_app     # dashboard
  curl http://localhost:$port_api/api/health
  open http://localhost:$port_api/swagger

${C_DIM}Or let pyon do the spin-up for you:${C_R}
  pyon new $name --up              (adds the --up flag to auto-start + probe)

${C_DIM}Admin user (seeded automatically):${C_R}
  email:    admin@example.com
  password: change-me-now
EOF
  fi
}

cmd_update() {
  local dest="pyon-stack-latest"
  say "Fetching latest template into ./$dest/ ..."
  rm -rf "$dest"
  git clone --depth=1 "$PYON_REPO" "$dest" >/dev/null
  rm -rf "$dest/.git"
  ok "Done. Diff against your project to find upstream changes:"
  printf '  diff -ruN your-project/ %s/\n' "$dest"
}

# --- main -------------------------------------------------------------------
main() {
  if [ $# -eq 0 ]; then usage; exit 0; fi
  case "$1" in
    -h|--help) usage ;;
    -v|--version) cmd_version ;;
    new) shift; cmd_new "$@" ;;
    update) shift; cmd_update "$@" ;;
    *) die "Unknown command: $1 (try 'pyon --help')" ;;
  esac
}

main "$@"
