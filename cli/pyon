    "dark":  { "background":"H S% L%","foreground":"H S% L%","primary":"H S% L%","primary-foreground":"H S% L%","secondary":"H S% L%","secondary-foreground":"H S% L%","muted":"H S% L%","muted-foreground":"H S% L%","accent":"H S% L%","accent-foreground":"H S% L%","destructive":"H S% L%","destructive-foreground":"H S% L%","border":"H S% L%","input":"H S% L%","ring":"H S% L%","card":"H S% L%","card-foreground":"H S% L%" }
