# --- apply ------------------------------------------------------------------

apply_theme() {
  local proj="$1" theme="$2"
  local src="$proj/themes/$theme/theme.css"
  [ -f "$src" ] || die "Theme not found: $theme"
  cp "$src" "$proj/apps/web/src/app/globals.css"
  cp "$src" "$proj/apps/app/src/index.css"
  sed_inplace "s/__PYON_THEME__/$theme/g" "$proj/apps/web/src/app/layout.tsx"
  sed_inplace "s/__PYON_THEME__/$theme/g" "$proj/apps/app/index.html"
}

# Overlay palette (from file OR inline JSON via stdin when file is "-") on both
# CSS entry points. Idempotent when called once per scaffold.
apply_palette() {
  local proj="$1" src="$2"   # src = path to palette JSON, or "none"
  [ "$src" = "none" ] && return 0
  [ -f "$src" ] || die "Palette file not found: $src"
  local web="$proj/apps/web/src/app/globals.css"
  local app="$proj/apps/app/src/index.css"
  local light_block dark_block
  light_block=$(jq -r '
    .light // {} | to_entries
    | map("    --" + .key + ": " + .value + ";") | .[]
  ' <"$src")
  dark_block=$(jq -r '
    .dark // {} | to_entries
    | map("    --" + .key + ": " + .value + ";") | .[]
  ' <"$src")
  local overlay
  overlay=$(cat <<EOF

/* pyon palette overlay */
@layer base {
  :root {
$light_block
  }
  .dark {
$dark_block
  }
}
EOF
)
  printf '%s\n' "$overlay" >> "$web"
  printf '%s\n' "$overlay" >> "$app"
}

# Insert Google Fonts link + override --font-sans/--font-mono.
apply_font() {
  local proj="$1" font="$2"
  [ "$font" = "none" ] && return 0
  local reg="$proj/fonts/fonts.json"
  [ -f "$reg" ] || die "fonts registry missing at $reg"
  local url family kind
  url=$(jq -r --arg id "$font" '.fonts[] | select(.id==$id) | .google_url // empty' <"$reg")
  family=$(jq -r --arg id "$font" '.fonts[] | select(.id==$id) | .css_family // empty' <"$reg")
  kind=$(jq -r --arg id "$font" '.fonts[] | select(.id==$id) | .kind // "sans"' <"$reg")
  [ -z "$url" ] && die "Unknown font: $font"
  local link_tsx link_html esc_url
  esc_url=$(printf '%s' "$url" | sed -e 's/[\/&]/\\&/g')

  # Next.js layout.tsx
  link_tsx='<link rel="preconnect" href="https:\/\/fonts.googleapis.com" \/><link rel="preconnect" href="https:\/\/fonts.gstatic.com" crossOrigin="anonymous" \/><link rel="stylesheet" href="'"$esc_url"'" \/>'
  sed_inplace "s|{/\* __PYON_FONT_LINK__ \*/}|$link_tsx|" "$proj/apps/web/src/app/layout.tsx"

  # Vite index.html
  link_html='<link rel="preconnect" href="https:\/\/fonts.googleapis.com"><link rel="preconnect" href="https:\/\/fonts.gstatic.com" crossorigin><link rel="stylesheet" href="'"$esc_url"'">'
  sed_inplace "s|<!-- __PYON_FONT_LINK__ -->|$link_html|" "$proj/apps/app/index.html"

  # CSS var override
  local override
  if [ "$kind" = "mono" ]; then
    override=$(printf '\n@layer base { :root { --font-mono: %s; } }\n' "$family")
  else
    override=$(printf '\n@layer base { :root { --font-sans: %s; } }\n' "$family")
  fi
  printf '%s' "$override" >> "$proj/apps/web/src/app/globals.css"
  printf '%s' "$override" >> "$proj/apps/app/src/index.css"
}

# Substitute every __PYON_COPY_<KEY>__ placeholder using an object under the
# top-level "copy" field in the given JSON (or the object itself if flat).
apply_copy() {
  local proj="$1" src="$2"
  [ -f "$src" ] || die "Copy JSON not found: $src"
  # Normalise to a flat object: prefer .copy, else the whole object (minus _description).
  local flat
  flat=$(jq '.copy // (. | del(.["_description"]))' <"$src")
  # Find files with any __PYON_COPY_*__ tokens.
  local targets
  targets=$(mktemp)
  ( cd "$proj" && grep -rlE '__PYON_COPY_[A-Z0-9_]+__' \
      --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=bin \
      --exclude-dir=obj --exclude-dir=.next --exclude-dir=dist \
      --exclude-dir=themes --exclude-dir=palettes --exclude-dir=fonts \
      --exclude-dir=cli . 2>/dev/null || true ) > "$targets"

  # Build a sed script: one s///g per copy key. We flatten any embedded
  # newlines to a single space because BSD sed interprets `\n` in the
  # replacement as a real newline, which would corrupt C# double-quoted
  # strings and JSX attribute values.
  local sed_script
  sed_script=$(mktemp)
  jq -r '
    to_entries[]
    | "s|__PYON_COPY_" + .key + "__|" +
      ( .value
        | gsub("\r"; "")
        | gsub("\n"; " ")
        | gsub("\\\\"; "\\\\\\\\")
        | gsub("&"; "\\&")
        | gsub("\\|"; "\\|")
      ) + "|g"
  ' <<<"$flat" > "$sed_script"

  while IFS= read -r rel; do
    [ -z "$rel" ] && continue
    local f="$proj/$rel"
    [ -f "$f" ] || continue
    if sed --version >/dev/null 2>&1; then
      sed -i -f "$sed_script" "$f"
    else
      sed -i '' -f "$sed_script" "$f"
    fi
  done < "$targets"
  rm -f "$targets" "$sed_script"
}

# Merge a full-brand JSON (from ai_scrape_brand) into explicit vars.
# Writes chosen theme, font, palette-file-path, copy-file-path to caller.
# Sets globals: CHOSEN_THEME CHOSEN_FONT PALETTE_FILE COPY_FILE
digest_brand_json() {
  local proj="$1" brand_json_path="$2"
  local theme font
  theme=$(jq -r '.theme // empty' <"$brand_json_path")
  font=$(jq -r  '.font // empty'  <"$brand_json_path")
  if in_list "$theme" $PYON_THEMES; then CHOSEN_THEME="$theme"; fi
  if in_list "$font"  $PYON_FONTS;  then CHOSEN_FONT="$font";  fi
  # Palette: extract .palette subtree as a palette JSON file.
  PALETTE_FILE="$proj/.pyon-palette.json"
  jq '.palette // {}' <"$brand_json_path" > "$PALETTE_FILE"
  # Copy: extract .copy subtree.
  COPY_FILE="$proj/.pyon-copy.json"
  jq '{copy: (.copy // {})}' <"$brand_json_path" > "$COPY_FILE"
}

# Merge (overlay) a generated copy JSON onto the fallback copy so every key is
# populated. Writes result to $out.
merge_copy() {
  local fallback="$1" generated="$2" out="$3"
  # Both .copy or flat.
  local fb gen
  fb=$(jq '.copy // (. | del(.["_description"]))' <"$fallback")
  gen=$(jq '.copy // .' <"$generated")
  jq -n --argjson fb "$fb" --argjson gen "$gen" '{copy: ($fb + $gen)}' > "$out"
}

# Synthesize a palette JSON from 3 hex inputs (primary / background / accent).
palette_from_hex() {
  local primary="$1" background="$2" accent="$3" out="$4"
  local p_hsl b_hsl a_hsl
  p_hsl=$(hex_to_hsl "$primary")
  b_hsl=$(hex_to_hsl "$background")
  a_hsl=$(hex_to_hsl "$accent")
  cat >"$out" <<EOF
{
  "name": "Custom",
  "light": {
    "background": "$b_hsl",
    "foreground": "240 10% 3.9%",
    "card": "$b_hsl",
    "card-foreground": "240 10% 3.9%",
    "primary": "$p_hsl",
    "primary-foreground": "0 0% 100%",
    "secondary": "240 4.8% 95.9%",
    "secondary-foreground": "240 5.9% 10%",
    "muted": "240 4.8% 95.9%",
    "muted-foreground": "240 3.8% 46.1%",
    "accent": "$a_hsl",
    "accent-foreground": "0 0% 100%",
    "destructive": "0 84.2% 60.2%",
    "destructive-foreground": "0 0% 98%",
    "border": "240 5.9% 90%",
    "input": "240 5.9% 90%",
    "ring": "$p_hsl"
  },
  "dark": {
    "background": "240 10% 3.9%",
    "foreground": "0 0% 98%",
    "card": "240 10% 6%",
    "card-foreground": "0 0% 98%",
    "primary": "$p_hsl",
    "primary-foreground": "0 0% 100%",
    "secondary": "240 3.7% 15.9%",
    "secondary-foreground": "0 0% 98%",
    "muted": "240 3.7% 15.9%",
    "muted-foreground": "240 5% 64.9%",
    "accent": "$a_hsl",
    "accent-foreground": "0 0% 100%",
