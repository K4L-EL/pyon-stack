# Copy to .env and fill values before running docker compose.
# The CLI generates this file automatically when scaffolding.

# --- API ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:__PYON_PORT_API__
ConnectionStrings__Default=Host=postgres;Port=5432;Database=__PYON_DB__;Username=pyon;Password=pyon
Jwt__Secret=__PYON_JWT_SECRET__
Jwt__Issuer=__PYON_NAME__
Jwt__Audience=__PYON_NAME__
Seed__AdminEmail=admin@example.com
Seed__AdminPassword=change-me-now

# --- Postgres ---
POSTGRES_DB=__PYON_DB__
POSTGRES_USER=pyon
POSTGRES_PASSWORD=pyon

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:__PYON_PORT_API__
NEXT_PUBLIC_APP_URL=http://localhost:__PYON_PORT_APP__

# --- App (Vite) ---
VITE_API_URL=http://localhost:__PYON_PORT_API__
